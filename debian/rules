#!/usr/bin/make -f

repoversion=$(shell LANG=C aptitude show flexplorer | grep Version: | awk '{print $$2}')
nextversion=$(shell echo $(repoversion) | perl -ne 'chomp; print join(".", splice(@{[split/\./,$$_]}, 0, -1), map {++$$_} pop @{[split/\./,$$_]}), "\n";')


%:
	dh $@ --with phpcomposer


override_dh_prep:
	rm -rf docs; mkdir docs
	phpdoc -d src --defaultpackagename=MainPackage
	mv .phpdoc/build/* docs
	dh_prep

override_dh_install:
	dh_install
	# Install Debian autoloader
	install -D -m 0644 debian/autoload.php debian/flexplorer/usr/share/php/flexplorer/autoload.php
	sed -i -e 's/\.\.\/\//.\/\//g' debian/flexplorer/usr/share/flexplorer/about.php
	sed -i -e 's/..../\/usr\/share\/php\/flexplorer/g' debian/flexplorer/usr/share/flexplorer/includes/Init.php
	sed -i -e 's/..\/i18n/\/usr\/share\/locale/g' debian/flexplorer/usr/share/flexplorer/includes/Init.php
	sed -i "s|'../.env'|'/etc/flexplorer/.env'|g" debian/flexplorer/usr/share/flexplorer/includes/Init.php
	sed -i "s|'../configurations/'|'/etc/flexplorer/'|g" debian/flexplorer/usr/share/flexplorer/includes/config.php
	sed -i "s|'../backups'|'/var/lib/flexplorer/backups'|g" debian/flexplorer/usr/share/flexplorer/includes/config.php
	sed -i -e "s|\.'/composer\.lock'|.'/autoload.php'|g" \
		-e "s|'../composer.lock'|'/var/lib/flexplorer/autoload.php'|g" \
		debian/flexplorer/usr/lib/flexplorer/classes/ui/PageBottom.php


override_dh_clean:
	debconf-updatepo
	dh_clean

release:
	echo Release v$(nextversion)
	dch -v $(nextversion) `git log -1 --pretty=%B | head -n 1`
	debuild -i -us -uc -b
	git commit -a -m "Release v$(nextversion)"
	git tag -a $(nextversion) -m "version $(nextversion)"

